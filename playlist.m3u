import json
import os
import sys
import requests

OUTPUT_FILE_NAME = "playlist.m3u"
EPG_URL = "https://avkb.short.gy/jioepg.xml.gz"

def fetch_data(url):
    print("Fetching Zee5 JSON...")

    try:
        r = requests.get(url, timeout=15)
        r.raise_for_status()
        return r.json()
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)


def json_to_m3u(data):
    # 🔥 IMPORTANT CHANGE
    channels = data.get("channels")

    if not isinstance(channels, list):
        print("Invalid format: 'channels' list not found")
        sys.exit(1)

    print(f"Converting {len(channels)} Zee5 channels...")

    m3u = [f'#EXTM3U x-tvg-url="{EPG_URL}"']

    for ch in channels:
        name = ch.get("name", "Unknown")
        logo = ch.get("logo", "")
        url = ch.get("mpd")

        if not url:
            print(f"Skipping {name} (no MPD)")
            continue

        # --- EXTINF ---
        m3u.append(f'#EXTINF:-1 tvg-name="{name}" tvg-logo="{logo}" group-title="ZEE5",{name}')

        # --- DRM (ClearKey) ---
        clearkey = ch.get("clearkey")
        if clearkey:
            key_id = clearkey.get("keyId")
            key = clearkey.get("key")

            if key_id and key:
                m3u.append('#KODIPROP:inputstream.adaptive.license_type=clearkey')
                m3u.append(f'#KODIPROP:inputstream.adaptive.license_key={key_id}:{key}')

        # --- Headers (important for OTT Navigator) ---
        m3u.append('#EXTVLCOPT:http-user-agent=Mozilla/5.0')

        # --- URL ---
        m3u.append(url)

    with open(OUTPUT_FILE_NAME, "w", encoding="utf-8") as f:
        f.write("\n".join(m3u))

    print(f"✅ Zee5 playlist ready: {OUTPUT_FILE_NAME}")


def main():
    url = os.getenv("JSON_SOURCE_URL")

    if not url:
        print("Set JSON_SOURCE_URL")
        sys.exit(1)

    data = fetch_data(url)
    json_to_m3u(data)


if __name__ == "__main__":
    main()
